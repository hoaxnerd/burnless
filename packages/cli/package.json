{
  "name": "burnless",
  "version": "0.1.0",
  "description": "The Burnless CLI — drive your Burnless instance from the terminal over MCP",
  "license": "MIT",
  "type": "module",
  "bin": {
    "burnless": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@burnless/db": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.38.0",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@burnless/ai": "workspace:*",
    "@types/node": "^22.19.15",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.25.76"
  }
}
