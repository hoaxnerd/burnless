# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/burnless"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth (optional — social login) ──────────────────────────────────────────
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── AI (optional — AI companion features) ───────────────────────────────────
# AI_PROVIDER=anthropic          # anthropic | openai | openrouter
# AI_MODEL=                      # model ID override
# AI_API_KEY=                    # generic key (takes precedence)
# AI_BASE_URL=                   # custom provider URL
# ANTHROPIC_API_KEY=             # legacy: direct Anthropic key
# OPENAI_API_KEY=                # legacy: direct OpenAI key

# ── Billing (optional — Stripe integration) ─────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# STRIPE_TEAM_PRICE_ID=

# ── Monitoring (optional) ───────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=

# ── Email (optional — transactional emails) ─────────────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM="noreply@burnless.com"
