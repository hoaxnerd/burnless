# ── Docker Compose local dev environment ──────────────────────────────────────
# Copy to .env and adjust as needed: cp .env.docker .env

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql://burnless:burnless@localhost:5432/burnless
# --- Datastore driver (S2) ---
# This docker env uses the Postgres service above. To run embedded PGLite instead,
# unset DATABASE_URL (BURNLESS_DB_DRIVER=pglite forces it). Options:
#   BURNLESS_DB_DRIVER=pglite | postgres   (overrides DATABASE_URL inference)
#   BURNLESS_DATA_DIR=                     (PGLite data dir, default ~/.burnless/data)
#   BURNLESS_AUTO_MIGRATE=                 (default: true for PGLite, false for postgres)
# BURNLESS_MIGRATIONS_DIR: override the migrations folder (needed only for bundled/standalone builds where the default source-relative path doesn't resolve; e.g. /app/packages/db/drizzle). Leave unset for source/dev.
# BURNLESS_MIGRATIONS_DIR=

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=docker-dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Provider (Ollama on your HOST machine — local LLM, no API key needed) ──
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
# Targets the Ollama running on your host (install + `ollama pull gemma3:12b` first).
# Override per-tier: AI_MODEL_OLLAMA_FAST=gemma3:4b

# To use cloud providers instead, comment out the above and set:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings (Ollama nomic-embed-text — local, 768 dimensions) ─────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── Web Search + Crawl (keyless, no Docker) ──────────────────────────────────
# Defaults to DuckDuckGo search + direct-fetch crawl — no service or key needed.
# Opt-in alternatives: WEB_SEARCH_PROVIDER=tavily + TAVILY_API_KEY=...

# ── Email (console — dev default) ────────────────────────────────────────────
# Dev logs emails to stdout (no SMTP service needed). For SMTP capture, run your
# own Mailpit and set: EMAIL_PROVIDER=smtp / SMTP_HOST=localhost / SMTP_PORT=1025.
EMAIL_PROVIDER=console
EMAIL_FROM=Burnless <noreply@burnless.app>

# ── Redis (OPTIONAL, cloud-only) ───────────────────────────────────────────────
# Self-host uses an in-memory rate-limiter. Redis is only for the hosted/cloud path.
# Start it with `docker compose --profile cloud up -d`, then uncomment:
# REDIS_URL=redis://localhost:6380

# ── Cron (local worker) ──────────────────────────────────────────────────────
CRON_SECRET=docker-dev-cron-secret

# ── OAuth (optional — leave blank to skip social login) ───────────────────────
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
