# ── Docker Compose local dev environment ──────────────────────────────────────
# Copy to .env and adjust as needed: cp .env.docker .env

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
DATABASE_URL=postgresql://burnless:burnless@localhost:5432/burnless
# --- Datastore driver (S2) ---
# This docker env uses the Postgres service above. To run embedded PGLite instead,
# unset DATABASE_URL (BURNLESS_DB_DRIVER=pglite forces it). Options:
#   BURNLESS_DB_DRIVER=pglite | postgres   (overrides DATABASE_URL inference)
#   BURNLESS_DATA_DIR=                     (PGLite data dir, default ~/.burnless/data)
#   BURNLESS_AUTO_MIGRATE=                 (default: true for PGLite, false for postgres)

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=docker-dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI Provider (Ollama — local LLM, no API key needed) ──────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
# Default models pulled by docker compose: gemma3:12b + nomic-embed-text
# Override per-tier: AI_MODEL_OLLAMA_FAST=gemma3:4b

# To use cloud providers instead, comment out the above and set:
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings (Ollama nomic-embed-text — local, 768 dimensions) ─────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── Web Search (SearXNG — local meta search engine) ──────────────────────────
# UI: http://localhost:8888 — the AI uses this as a web search tool
WEB_SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8888
# Production: WEB_SEARCH_PROVIDER=tavily + TAVILY_API_KEY=...

# ── Crawl (Crawl4AI — local) ─────────────────────────────────────────────────
CRAWL_PROVIDER=crawl4ai
CRAWL4AI_URL=http://localhost:11235
CRAWL4AI_API_TOKEN=burnless-dev-token

# ── Email (Mailpit SMTP — local) ─────────────────────────────────────────────
# Web UI: http://localhost:8025 — all emails are captured here
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
MAILPIT_API_PORT=8025
EMAIL_FROM=Burnless <noreply@burnless.app>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── Cron (local worker) ──────────────────────────────────────────────────────
CRON_SECRET=docker-dev-cron-secret

# ── OAuth (optional — leave blank to skip social login) ───────────────────────
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
