{
  "name": "burnless",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate --filter=@burnless/db",
    "db:migrate": "turbo db:migrate --filter=@burnless/db",
    "db:push": "turbo db:push --filter=@burnless/db",
    "db:studio": "pnpm --filter @burnless/db db:studio",
    "db:seed": "turbo db:seed --filter=@burnless/db",
    "db:seed-test-accounts": "pnpm --filter @burnless/db db:seed-test-accounts",
    "setup": "pnpm install && pnpm db:push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "./scripts/docker-dev.sh",
    "docker:reset": "./scripts/docker-dev.sh --reset",
    "cron:worker": "npx tsx scripts/cron-worker.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.26.1",
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7"
  }
}
