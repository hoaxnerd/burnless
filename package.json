{
  "name": "burnless-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "check": "turbo type-check lint",
    "db:generate": "turbo db:generate --filter=@burnless/db",
    "db:migrate": "turbo db:migrate --filter=@burnless/db",
    "db:push": "turbo db:push --filter=@burnless/db",
    "db:studio": "pnpm --filter @burnless/db db:studio",
    "db:seed": "turbo db:seed --filter=@burnless/db",
    "db:seed-test-accounts": "pnpm --filter @burnless/db db:seed-test-accounts",
    "migrate": "turbo db:migrate --filter=@burnless/db",
    "generate": "turbo db:generate --filter=@burnless/db",
    "studio": "pnpm --filter @burnless/db db:studio",
    "seed": "turbo db:seed --filter=@burnless/db",
    "e2e": "pnpm --filter @burnless/web test:e2e",
    "e2e:ui": "pnpm --filter @burnless/web test:e2e:ui",
    "test:web": "pnpm --filter @burnless/web test",
    "test:db": "pnpm --filter @burnless/db test",
    "setup": "pnpm install && pnpm db:push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "./scripts/docker-dev.sh",
    "docker:reset": "./scripts/docker-dev.sh --reset",
    "cron:worker": "npx tsx scripts/cron-worker.ts",
    "build:artifact": "tsx scripts/build-artifact.ts",
    "test:artifact": "bash scripts/artifact/acceptance-matrix.sh"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.8.20"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7"
  }
}
